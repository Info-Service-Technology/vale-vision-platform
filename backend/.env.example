SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=admin@sensx.com
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
