ENVIRONMENT=dev
APP_NAME=Vale Vision API
FRONTEND_PUBLIC_URL=http://localhost:5174
API_PUBLIC_URL=http://localhost:8000
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=vale_vision
MYSQL_USER=app
MYSQL_PASSWORD=change_me
AWS_REGION=sa-east-1
S3_BUCKET_RAW=vale-vision-raw-dev
S3_BUCKET_DEBUG=vale-vision-debug-dev
JWT_SECRET_KEY=trocar-em-producao
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

EMAIL_ENABLED=false
EMAIL_FROM_NAME=SensX Vision Platform
EMAIL_FROM_ADDRESS=no-reply@sensxvisionplatform.com
EMAIL_REPLY_TO=admin@sensx.com
EMAIL_SUPPORT_ADDRESS=admin@sensx.com
